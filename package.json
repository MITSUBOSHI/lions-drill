{
  "name": "lions-drill",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "next-sitemap && node scripts/generate-pwa-assets.mjs",
    "start": "next start",
    "lint": "prettier --check 'src/**/*.{ts,tsx}' && next lint --no-cache",
    "fix": "prettier --write 'src/**/*.{ts,tsx}' && next lint --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "clean": "rm -rf .next out",
    "test:e2e": "npm run clean && npm run build && playwright test",
    "cap:build": "CAPACITOR=true npm run build",
    "cap:sync": "npm run cap:build && npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@next/third-parties": "^15.1.7",
    "html2canvas": "^1.4.1",
    "next": "^15.1.7",
    "next-themes": "^0.4.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^14.2.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.19",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.14",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "next-sitemap": "^4.2.3",
    "node-html-parser": "^7.1.0",
    "postcss": "^8.5.8",
    "prettier": "^3.5.2",
    "serve": "^14.2.5",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
